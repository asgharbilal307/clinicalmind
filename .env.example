# ClinicalMind Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=ClinicalMind
APP_VERSION=1.0.0
DEBUG=false

# API Keys
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
PUBMED_API_KEY=

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=clinical_evidence
QDRANT_VECTOR_SIZE=384

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# PubMed Settings
PUBMED_EMAIL=researcher@example.com
PUBMED_TOOL=ClinicalMind
PUBMED_MAX_RESULTS=50

# LLM Settings
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2000

# Chunking Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval Settings
TOP_K=10
BM25_K1=1.5
BM25_B=0.75